# Cache
.cache/
.turbo/
.parcel-cache/

# Claude Code conversation exports (/export)
/20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt

# Eval outputs (generated by npm run eval:a1)
evals/out/

# 本地多源评测数据：含第三方全文，不入仓（项目原则「不复制全文存储」）。
# 由 npm run eval:build-local 从 .data 重建；只提交指标/基线，不提交内容。
evals/dataset/*.local.jsonl

# Local data: SQLite (WAL/SHM) + 报告正文 FS（挂持久卷，不入仓）
.data/

# TS incremental build info
*.tsbuildinfo
.claude/
