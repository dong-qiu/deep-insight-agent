node_modules/
.pnp.*
.yarn/

# Build output
dist/
build/
.next/
out/

# Env & secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
.obsidian/
*.swp

# Test / coverage
coverage/
