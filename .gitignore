# Dependencies
# 注意：不带尾部斜杠——尾斜杠模式只匹配目录，不匹配「指向 node_modules 的符号链接」，
# 导致 worktree 里手动建的 node_modules 软链被 `git add -A` 误纳入（#33 即此回归）。
node_modules
.pnp.*
.yarn/

# Build output
dist/
build/
.next/
out/

# Env & secrets
.env
.env.*
!.env.example
!.env.compose.example
*.pem
*.key

# 云部署本地态（含部署参数 / 公网 IP / 实例 ID，不入库）
ops/aws/config.sh
ops/aws/.vm-ip
ops/aws/.vm-id

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
.obsidian/
*.swp

# Test / coverage
coverage/
.nyc_output/

# Cache
.cache/
.turbo/
.parcel-cache/

# Claude Code conversation exports (/export)
/20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt

# Eval outputs (generated by npm run eval:a1)
evals/out/

# 本地多源评测数据：含第三方全文，不入仓（项目原则「不复制全文存储」）。
# 由 npm run eval:build-local 从 .data 重建；只提交指标/基线，不提交内容。
evals/dataset/*.local.jsonl

# Local data: SQLite (WAL/SHM) + 报告正文 FS（挂持久卷，不入仓）
.data/

# TS incremental build info
*.tsbuildinfo
.claude/
deep-insight-cli_accessKeys.csv
