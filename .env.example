# Anthropic API key —— A1 验证实跑（npm run eval:a1）必需
# 复制本文件为 .env.local 并填入真实 key（.env* 已在 .gitignore，不会入仓）
ANTHROPIC_API_KEY=sk-ant-...

# 覆盖默认模型（架构默认 分析=sonnet-4-6 / 校验=opus-4-7）
# 校验模型必须独立于分析模型（同源偏差约束），否则启动即报错。
# ⚠️ 经 Opus-only 中转站时**必须**把 analyzer 显式设为 Opus（否则 analyze 打到 sonnet → 失败）：
#   ANALYZER_MODEL=claude-opus-4-6   # 与下方 validator 不同即可
# ANALYZER_MODEL=claude-sonnet-4-6
# VALIDATOR_MODEL=claude-opus-4-7

# 可选：经第三方中转站时设置（直连 Anthropic 则留空）
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# 经第三方中转站时建议关校验思考（部分中转站 thinking 计价虚高/不稳，见 docs/practice-log.md）
# VALIDATOR_THINKING=0

# 鉴权（NextAuth）—— Web 应用必需
# AUTH_SECRET：随机串，`openssl rand -base64 32` 生成
AUTH_SECRET=
# 管理员凭据（MVP 用 Credentials 登录；magic-link 待接 SMTP 后启用）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# 定时管线（Docker：容器内 supercronic 按 ops/crontab 触发 POST /api/cron）
# CRON_SECRET：随机串（`openssl rand -base64 32`）。未设置则 /api/cron 返回 503 禁用。
CRON_SECRET=
# 可选：单次跑回看窗口小时数（默认 168 = 7 天），按主题切此窗口内的 ContentItem
# PIPELINE_WINDOW_HOURS=168
# 可选：冷启动（topic 无历史报告）自动产"首版综述"initial_digest——更宽回看窗口 + 更多条，给新主题有份量的首报
# INITIAL_DIGEST_WINDOW_HOURS=720   # 默认 720 = 30 天
# INITIAL_DIGEST_ITEMS=25           # 默认 25（暖启动后回落到 PIPELINE_ITEMS_PER_TOPIC=15）

# 可选：失败告警 webhook（Run 失败时 fire-and-forget POST）。按 URL 自动识别渠道并翻译 payload：
#   feishu（默认主推）/ ntfy / slack / discord / generic。未设则不发（失败仍落 Run + error 日志）。
#   operator 配置、非用户输入。详见 docs/launch/operations.md §12。
# ALERT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx
# 可选：显式指定渠道，覆盖 URL 自动识别（自建 ntfy 用自定义域名时设 ntfy）。取值 feishu/ntfy/slack/discord/generic
# ALERT_CHANNEL=feishu
# 可选：飞书群机器人开「签名校验」安全模式时填密钥（自动加 timestamp+sign）；用「关键词」模式则留空
# ALERT_FEISHU_SECRET=
# 可选：告警发送超时毫秒（默认 5000）
# ALERT_TIMEOUT_MS=5000

# 可选：报告推送（生成完报告主动推给用户，点进 = 报告 deep-link）。复用上面同一 ALERT_WEBHOOK 渠道。
#   独立 opt-in：默认关（失败告警是运维信号、报告推送是日常内容流，混同渠道默认全开会刷屏）。
#   置 1 开启；空 brief（"本期无重要事件"）自动跳过，deep_dive/initial_digest 始终推。
# REPORT_PUSH=1
# 用户可达的站点根地址，用于拼报告 deep-link（如 https://insight.example.com 或 http://<EC2-IP>:3000）。
#   缺失则推送照发、仅不带链接。注意与容器内网 APP_URL（http://app:3000）区分。
# PUBLIC_BASE_URL=https://insight.example.com

# 可选：成本预算控制（A5 · DCP-3 ①，见 docs/launch/operations.md §14）。配上限即触顶自动熔断定时管线。
#   ⚠️ 持久化提醒：这几个 + 上面 REPORT_PUSH/PUBLIC_BASE_URL 是「生产手动配的运行时配置」。
#   ops/aws/deploy.sh 会用本地 .env.local 全量覆盖远程——务必把生产值写进本地 .env.local，否则
#   下次 deploy 会静默抹掉熔断/推送（gen-env.sh 已自动继承旧值；deploy.sh 缺失会告警）。
#   取消注释时只删行首 #、保留裸 KEY=VAL（勿加行内注释，会被当值导致解析失败/熔断失效）。
# 日成本上限 USD；触顶熔断（跳过剩余 topic）+ 告警。未设 = 不限
# COST_LIMIT_DAILY=5
# 月成本上限 USD（自然月 UTC）；同上熔断 + 告警。未设 = 不限
# COST_LIMIT_MONTHLY=80
# 触顶前告警阈值百分比（默认 80）
# COST_ALERT_PCT=80

# —— 仅容器部署需要（本地 dev 勿设）——
# INSIGHT_CONFIG_PATH：standalone 打包后 defaults.yaml 的绝对路径（Dockerfile 已设 /app/config/defaults.yaml）
# DATA_DIR / DB_PATH：SQLite 库与归档目录（Dockerfile 已设 /data，挂持久卷）
