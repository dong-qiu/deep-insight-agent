# Compose CLI 变量（docker compose 自动读同目录 .env；与容器运行时的 .env.local 是两回事）。
# 多 worktree 并行本机起多套时复制本文件为 .env，每个 worktree 填不同的值。
# 不建 .env 则回落到 docker-compose.yml 的 name: deep-insight 与端口 3000（单机生产部署行为）。
#
# 用法：cp .env.compose.example .env

# 工程名：决定容器名前缀与数据卷全名 <COMPOSE_PROJECT_NAME>_insight-data。
# 各 worktree 取不同名 → 容器与数据卷天然隔离，互不串库。
COMPOSE_PROJECT_NAME=deep-insight-dev

# app 对外端口（容器内仍是 3000）。多套并行时各 worktree 取不同端口避免冲突。
APP_PORT=3000
